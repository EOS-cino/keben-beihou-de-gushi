---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<BaseLayout title="页面走丢了 - 课文背后的故事" description="你访问的页面不存在">
  <section class="not-found">
    <div class="not-found-illustration">
      <svg width="200" height="160" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="20" y="20" width="160" height="120" rx="8" fill="#fef9ed" stroke="#d4c9a8" stroke-width="2"/>
        <path d="M20 28 Q20 20 28 20 L100 20 L100 140 L28 140 Q20 140 20 132 Z" fill="#fdf6e8" stroke="#d4c9a8" stroke-width="1.5"/>
        <line x1="35" y1="45" x2="85" y2="45" stroke="#c0a878" stroke-width="2" stroke-linecap="round"/>
        <line x1="35" y1="58" x2="75" y2="58" stroke="#c0a878" stroke-width="2" stroke-linecap="round"/>
        <line x1="35" y1="71" x2="80" y2="71" stroke="#c0a878" stroke-width="2" stroke-linecap="round"/>
        <line x1="35" y1="84" x2="70" y2="84" stroke="#c0a878" stroke-width="2" stroke-linecap="round"/>
        <text x="130" y="95" font-family="serif" font-size="48" font-weight="bold" fill="#e07856" text-anchor="middle">404</text>
        <circle cx="55" cy="115" r="6" fill="#3a7d5c" opacity="0.6"/>
        <circle cx="70" cy="115" r="6" fill="#3a7d5c" opacity="0.4"/>
        <line x1="61" y1="115" x2="64" y2="115" stroke="#3a7d5c" stroke-width="1.5"/>
      </svg>
    </div>
    <h1>这一页课文走丢了</h1>
    <p>也许它被风吹到了别的书架上，也许链接拼写有误。<br />别担心，下面几条路都能带你回到故事里。</p>
    <div class="not-found-actions">
      <a class="button primary" href={withBase("/lessons/")}>浏览课文库</a>
      <a class="button secondary" href={withBase("/")}>回到首页</a>
      <a class="button secondary" href={withBase("/curriculum/")}>看教材目录</a>
    </div>
  </section>
</BaseLayout>
