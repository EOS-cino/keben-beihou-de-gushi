---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const lessons = await getCollection("lessons");
const gradeOrder = ["一年级", "二年级", "三年级", "四年级", "五年级", "六年级"];

// Flatten every glossary entry across all lessons into reviewable flashcards.
// Each card keeps its source lesson so the back face can link back to it.
const cards = lessons.flatMap((lesson) =>
  lesson.data.glossary.map((g) => ({
    term: g.term,
    pinyin: g.pinyin,
    meaning: g.meaning,
    lessonTitle: lesson.data.title,
    grade: lesson.data.grade,
    slug: lesson.slug,
  })),
);

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

// Pre-compute lesson href on the server so the client just reads the string.
const cardsJson = cards.map((c) => ({
  ...c,
  lessonHref: withBase(`/lessons/${c.slug}/`),
}));

const payload = { cards: cardsJson, gradeOrder };
---

<BaseLayout
  title="生字词卡片复习 - 课文背后的故事"
  description="翻卡片复习每篇课文的生字词，认识进阶、不认识回炉，用 Leitner 盒子法帮你高效记忆。"
>
  <section class="page-hero compact">
    <p class="eyebrow">复习工具</p>
    <h1>生字词卡片复习</h1>
    <p>
      翻卡片记生字：正面看词语和拼音，翻面看释义。认识的词进入更高阶的盒子、复习间隔变长；不认识的词回到第一个盒子，优先重练。
    </p>
  </section>

  <section class="flashcard-page" id="flashcardPage">
    <!-- 1. Grade filter -->
    <div class="flashcard-filter">
      <span class="flashcard-filter-label">按年级筛选：</span>
      <div class="flashcard-grade-btns" id="gradeBtns">
        <button class="flashcard-grade-btn active" data-grade="全部" type="button">全部</button>
        {gradeOrder.map((g) => (
          <button class="flashcard-grade-btn" type="button" data-grade={g}>{g}</button>
        ))}
      </div>
      <span class="flashcard-count" id="cardCount"></span>
      <button class="flashcard-reset" id="resetBtn" type="button" title="清空所有生字词的复习进度">重置进度</button>
    </div>

    <!-- 2. Card review area -->
    <div class="flashcard-review" id="reviewArea">
      <div class="flashcard-progress">
        <span class="flashcard-progress-text" id="progressText">第 0 / 0 张</span>
        <span class="flashcard-mode" id="modeBadge" hidden>错题重练</span>
      </div>

      <div class="flashcard-card" id="flashcard" role="button" tabindex="0" aria-label="点击翻面">
        <div class="flashcard-inner">
          <div class="flashcard-face flashcard-front">
            <p class="flashcard-pinyin" id="cardPinyin"></p>
            <h2 class="flashcard-term" id="cardTerm"></h2>
            <p class="flashcard-hint">点击卡片翻面看释义</p>
          </div>
          <div class="flashcard-face flashcard-back">
            <p class="flashcard-meaning" id="cardMeaning"></p>
            <a class="flashcard-meta" id="cardMeta" href="#"></a>
          </div>
        </div>
      </div>

      <div class="flashcard-actions">
        <button class="flashcard-btn flashcard-btn-wrong" id="btnWrong" type="button">不认识</button>
        <button class="flashcard-btn flashcard-btn-flip" id="btnFlip" type="button">翻面</button>
        <button class="flashcard-btn flashcard-btn-right" id="btnRight" type="button">认识</button>
      </div>
    </div>

    <!-- Empty state -->
    <div class="flashcard-empty" id="emptyState" hidden>
      <span class="flashcard-empty-icon">📭</span>
      <p>这个年级暂时没有生字词，换个年级试试吧。</p>
    </div>

    <!-- 3. Round stats -->
    <div class="flashcard-stats" id="statsArea">
      <div class="flashcard-stat">
        <span class="flashcard-stat-num" id="statRight">0</span>
        <span class="flashcard-stat-label">认识</span>
      </div>
      <div class="flashcard-stat">
        <span class="flashcard-stat-num" id="statWrong">0</span>
        <span class="flashcard-stat-label">不认识</span>
      </div>
      <div class="flashcard-stat">
        <span class="flashcard-stat-num" id="statRate">0%</span>
        <span class="flashcard-stat-label">正确率</span>
      </div>
    </div>

    <!-- 4. Round result -->
    <div class="flashcard-result" id="resultArea" hidden>
      <h2 id="resultTitle">本轮复习完成！</h2>
      <p id="resultSummary"></p>
      <div class="flashcard-result-actions">
        <button class="flashcard-btn flashcard-btn-right" id="btnAgain" type="button">再练一轮</button>
        <button class="flashcard-btn flashcard-btn-wrong" id="btnReviewWrong" type="button" hidden>复习错题</button>
      </div>
    </div>
  </section>

  <script type="application/json" id="flashcardData" set:html={JSON.stringify(payload)} is:inline />
</BaseLayout>

<script>
  // ---- Leitner spaced-repetition flashcard engine ----
  const STORAGE_KEY = "ketang-flashcard-stats";
  // Review interval (in days) for each of the 5 boxes. Box 1 is always due.
  const INTERVALS = [0, 1, 3, 7, 30];
  const DAY_MS = 86400000;

  type CardStat = { box: number; lastReview: number; correctCount: number; wrongCount: number };
  type FlashCard = {
    term: string;
    pinyin: string;
    meaning: string;
    lessonTitle: string;
    grade: string;
    slug: string;
    lessonHref: string;
  };

  const payload = JSON.parse(
    document.getElementById("flashcardData")?.textContent || "{}",
  ) as { cards: FlashCard[]; gradeOrder: string[] };
  const allCards: FlashCard[] = payload.cards || [];

  // ---- DOM references ----
  const gradeBtns = [...document.querySelectorAll<HTMLButtonElement>(".flashcard-grade-btn")];
  const cardCountEl = document.getElementById("cardCount")!;
  const progressText = document.getElementById("progressText")!;
  const modeBadge = document.getElementById("modeBadge")!;
  const flashcard = document.getElementById("flashcard")!;
  const cardPinyin = document.getElementById("cardPinyin")!;
  const cardTerm = document.getElementById("cardTerm")!;
  const cardMeaning = document.getElementById("cardMeaning")!;
  const cardMeta = document.getElementById("cardMeta") as HTMLAnchorElement;
  const btnWrong = document.getElementById("btnWrong") as HTMLButtonElement;
  const btnFlip = document.getElementById("btnFlip") as HTMLButtonElement;
  const btnRight = document.getElementById("btnRight") as HTMLButtonElement;
  const reviewArea = document.getElementById("reviewArea")!;
  const emptyState = document.getElementById("emptyState")!;
  const statsArea = document.getElementById("statsArea")!;
  const statRight = document.getElementById("statRight")!;
  const statWrong = document.getElementById("statWrong")!;
  const statRate = document.getElementById("statRate")!;
  const resultArea = document.getElementById("resultArea")!;
  const resultTitle = document.getElementById("resultTitle")!;
  const resultSummary = document.getElementById("resultSummary")!;
  const btnAgain = document.getElementById("btnAgain") as HTMLButtonElement;
  const btnReviewWrong = document.getElementById("btnReviewWrong") as HTMLButtonElement;
  const resetBtn = document.getElementById("resetBtn") as HTMLButtonElement;

  // ---- State ----
  let stats: Record<string, CardStat> = loadStats();
  let currentGrade = "全部";
  let currentDeck: FlashCard[] = [];
  let currentIndex = 0;
  let correctCount = 0;
  let wrongCount = 0;
  let wrongQueue: FlashCard[] = [];
  let isWrongReview = false;

  // ---- Persistence ----
  function loadStats(): Record<string, CardStat> {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
    } catch {
      return {};
    }
  }
  function saveStats() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(stats));
  }
  function getStat(term: string): CardStat {
    if (!stats[term]) {
      stats[term] = { box: 1, lastReview: 0, correctCount: 0, wrongCount: 0 };
    }
    return stats[term];
  }

  // ---- Deck building ----
  function poolForGrade(grade: string): FlashCard[] {
    return grade === "全部" ? allCards : allCards.filter((c) => c.grade === grade);
  }

  function isDue(card: FlashCard): boolean {
    const s = stats[card.term];
    if (!s || !s.lastReview) return true; // never reviewed -> always due
    const interval = INTERVALS[(s.box || 1) - 1] * DAY_MS;
    return Date.now() - s.lastReview >= interval;
  }

  // Prioritise lower boxes (box 1 first), then least-recently-reviewed.
  function sortByPriority(a: FlashCard, b: FlashCard): number {
    const ba = stats[a.term]?.box || 1;
    const bb = stats[b.term]?.box || 1;
    if (ba !== bb) return ba - bb;
    const la = stats[a.term]?.lastReview || 0;
    const lb = stats[b.term]?.lastReview || 0;
    return la - lb;
  }

  function buildDeck(grade: string): FlashCard[] {
    const pool = poolForGrade(grade);
    const due = pool.filter(isDue);
    const notDue = pool.filter((c) => !isDue(c));
    due.sort(sortByPriority);
    notDue.sort(sortByPriority);
    // If nothing is due, fall back to the whole pool so a round is still possible.
    return due.length ? due : notDue;
  }

  // ---- Rendering ----
  function updateCardCount() {
    cardCountEl.textContent = `共 ${poolForGrade(currentGrade).length} 个生字词`;
  }

  function renderCard() {
    if (currentIndex >= currentDeck.length) {
      finishRound();
      return;
    }
    const card = currentDeck[currentIndex];
    cardPinyin.textContent = card.pinyin;
    cardTerm.textContent = card.term;
    cardMeaning.textContent = card.meaning;
    cardMeta.href = card.lessonHref;
    cardMeta.textContent = `出处：《${card.lessonTitle}》 · ${card.grade}`;
    flashcard.classList.remove("flipped");
    progressText.textContent = `第 ${currentIndex + 1} / ${currentDeck.length} 张`;
  }

  function updateStats() {
    statRight.textContent = String(correctCount);
    statWrong.textContent = String(wrongCount);
    const total = correctCount + wrongCount;
    const rate = total ? Math.round((correctCount / total) * 100) : 0;
    statRate.textContent = `${rate}%`;
  }

  // ---- Round flow ----
  function startRound(deck: FlashCard[], wrongReview = false) {
    if (!deck || deck.length === 0) {
      showEmpty();
      return;
    }
    currentDeck = deck;
    currentIndex = 0;
    correctCount = 0;
    wrongCount = 0;
    wrongQueue = [];
    isWrongReview = wrongReview;

    emptyState.hidden = true;
    resultArea.hidden = true;
    reviewArea.hidden = false;
    statsArea.hidden = false;
    modeBadge.hidden = !wrongReview;

    renderCard();
    updateStats();
  }

  function answer(known: boolean) {
    if (currentIndex >= currentDeck.length) return;
    const card = currentDeck[currentIndex];
    const s = getStat(card.term);
    if (known) {
      s.box = Math.min((s.box || 1) + 1, 5);
      s.correctCount = (s.correctCount || 0) + 1;
      correctCount++;
    } else {
      s.box = 1; // back to the first box
      s.wrongCount = (s.wrongCount || 0) + 1;
      wrongCount++;
      wrongQueue.push(card);
    }
    s.lastReview = Date.now();
    saveStats();
    updateStats();
    currentIndex++;
    renderCard();
  }

  function finishRound() {
    reviewArea.hidden = true;
    resultArea.hidden = false;
    const total = correctCount + wrongCount;
    const rate = total ? Math.round((correctCount / total) * 100) : 0;
    resultTitle.textContent = isWrongReview ? "错题重练完成！" : "本轮复习完成！";
    let summary = `共 ${total} 个词：认识 ${correctCount} 个，不认识 ${wrongCount} 个，正确率 ${rate}%。`;
    if (wrongQueue.length > 0) {
      summary += ` 本轮有 ${wrongQueue.length} 个不认识的词，建议进入「复习错题」再练一遍。`;
    } else {
      summary += " 全部掌握，表现很棒！";
    }
    resultSummary.textContent = summary;
    btnReviewWrong.hidden = wrongQueue.length === 0;
    resultArea.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  function showEmpty() {
    reviewArea.hidden = true;
    statsArea.hidden = true;
    resultArea.hidden = true;
    emptyState.hidden = false;
  }

  // ---- Events ----
  flashcard.addEventListener("click", () => flashcard.classList.toggle("flipped"));
  flashcard.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      flashcard.classList.toggle("flipped");
    }
  });
  btnFlip.addEventListener("click", (e) => {
    e.stopPropagation();
    flashcard.classList.toggle("flipped");
  });
  btnRight.addEventListener("click", () => answer(true));
  btnWrong.addEventListener("click", () => answer(false));

  btnAgain.addEventListener("click", () => {
    startRound(buildDeck(currentGrade), false);
  });
  btnReviewWrong.addEventListener("click", () => {
    startRound([...wrongQueue], true);
  });

  gradeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      gradeBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      currentGrade = btn.dataset.grade || "全部";
      updateCardCount();
      startRound(buildDeck(currentGrade), false);
    });
  });

  resetBtn.addEventListener("click", () => {
    if (confirm("确定要清空所有生字词的复习进度吗？此操作不可撤销。")) {
      stats = {};
      localStorage.removeItem(STORAGE_KEY);
      startRound(buildDeck(currentGrade), false);
    }
  });

  // ---- Init ----
  updateCardCount();
  startRound(buildDeck(currentGrade), false);
</script>
