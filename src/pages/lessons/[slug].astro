---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LessonCard from "../../components/LessonCard.astro";
import { getLessonAuthors, authorSlug } from "../../data/authors";

export async function getStaticPaths() {
  const allLessons = (await getCollection("lessons")).sort((a, b) => {
    const gradeOrder = ["一年级", "二年级", "三年级", "四年级", "五年级", "六年级"];
    const ga = gradeOrder.indexOf(a.data.grade);
    const gb = gradeOrder.indexOf(b.data.grade);
    if (ga !== gb) return ga - gb;
    return a.data.volume.localeCompare(b.data.volume, "zh-CN");
  });

  return allLessons.map((lesson, i) => {
    // Enhanced related lessons: score by multiple dimensions
    const scored = allLessons
      .filter((l) => l.slug !== lesson.slug)
      .map((l) => {
        let score = 0;
        const reasons: string[] = [];

        // Same author (highest weight, but skip generic "佚名")
        const lessonAuthors = new Set(getLessonAuthors(lesson.data.author));
        const lAuthors = new Set(getLessonAuthors(l.data.author));
        const hasSharedAuthor = [...lessonAuthors].some((a) => lAuthors.has(a));
        if (hasSharedAuthor) {
          score += 10;
          reasons.push("same-author");
        }

        // Same theme (high weight)
        if (l.data.theme === lesson.data.theme) {
          score += 6;
          reasons.push("same-theme");
        }

        // Same era (medium weight)
        if (l.data.era === lesson.data.era) {
          score += 4;
          reasons.push("same-era");
        }

        // Same grade but different lesson (medium weight)
        if (l.data.grade === lesson.data.grade) {
          score += 3;
          reasons.push("same-grade");
        }

        return { lesson: l, score, reasons };
      })
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 4);

    return {
      params: { slug: lesson.slug },
      props: {
        lesson,
        prev: allLessons[i - 1] || null,
        next: allLessons[i + 1] || null,
        related: scored,
      },
    };
  });
}

const { lesson, prev, next, related } = Astro.props;
const { Content } = await render(lesson);
const data = lesson.data;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

const reasonLabels: Record<string, string> = {
  "same-author": "同作者",
  "same-theme": "同主题",
  "same-era": "同时代",
  "same-grade": "同年级",
};

// Reading time estimation (Chinese: ~300 chars/min)
const bodyText = lesson.body || "";
const charCount = bodyText.replace(/[#\-*\[\]\(\)>]/g, "").replace(/\s+/g, "").length;
const readingMinutes = Math.max(1, Math.round(charCount / 300));

// Parse authors for display and linking
const lessonAuthors = getLessonAuthors(data.author);

// JSON-LD Article structured data
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `《${data.title}》背后的故事`,
  description: data.summary,
  author: lessonAuthors.map((a) => ({ "@type": "Person", name: a })),
  articleSection: data.grade,
  keywords: [data.theme, data.grade, data.author, data.era].join(", "),
  inLanguage: "zh-CN",
  image: withBase(data.image),
};
---

<BaseLayout
  title={`《${data.title}》背后的故事 - 课文背后的故事`}
  description={data.summary}
  ogImage={data.image}
  ogType="article"
  jsonLd={articleJsonLd}
>
  <div class="reading-progress" id="readingProgress"></div>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="面包屑导航">
    <a href={withBase("/")}>首页</a>
    <span class="breadcrumb-sep">›</span>
    <a href={withBase("/lessons/")}>课文库</a>
    <span class="breadcrumb-sep">›</span>
    <a href={withBase("/lessons/")} class="breadcrumb-grade">{data.grade}</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">《{data.title}》</span>
  </nav>

  <article class="lesson-detail">
    <header class="lesson-hero">
      <div class="lesson-hero-text">
        <a class="back-link" href={withBase("/lessons/")}>← 返回课文库</a>
        <p class="eyebrow">{data.grade} · {data.volume} · {data.theme}</p>
        <h1>《{data.title}》<br />背后的故事</h1>
        <p class="lesson-subtitle">{data.subtitle}</p>
        <div class="meta-list">
          <span>作者：{lessonAuthors.map((a, i) => (
            <Fragment>{i > 0 && "、"}<a href={withBase(`/authors/${authorSlug(a)}/`)}>{a}</a></Fragment>
          ))}</span>
          <span>时代：{data.era}</span>
          <span>约 {charCount} 字 · {readingMinutes} 分钟</span>
        </div>
      </div>
      <div class="lesson-hero-image">
        <img src={withBase(data.image)} alt={data.imageAlt} />
      </div>
    </header>

    <aside class="notice">
      <span class="notice-icon">📌</span>
      本页不转载现行教材全文，只提供原创导读、背景故事与延伸阅读。正式学习时请回到课本原文。
    </aside>

    <section class="story-gallery" aria-label="课文插图">
      <figure>
        <img src={withBase(data.image)} alt={data.imageAlt} />
        <figcaption>课文现场</figcaption>
      </figure>
      <figure>
        <img src={withBase(data.chainImage)} alt={data.chainImageAlt} />
        <figcaption>{data.chainCaption}</figcaption>
      </figure>
    </section>

    <div class="lesson-layout" data-slug={lesson.slug}>
      <div class="article-body">
        <!-- Reading toolbar: font size + bookmark -->
        <div class="reading-toolbar">
          <div class="font-size-control">
            <span class="toolbar-label">字号</span>
            <button class="font-btn" data-size="small" type="button" aria-label="小号字体">A</button>
            <button class="font-btn active" data-size="medium" type="button" aria-label="标准字体">A</button>
            <button class="font-btn" data-size="large" type="button" aria-label="大号字体">A</button>
          </div>
          <button class="pinyin-toggle" id="pinyinToggle" type="button" aria-label="开启/关闭拼音" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span>拼音</span>
          </button>
          <button class="bookmark-btn" id="bookmarkBtn" type="button" aria-label="收藏课文" data-slug={lesson.slug}>
            <svg class="bookmark-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <span class="bookmark-text">收藏</span>
          </button>
          <button class="share-btn" id="shareBtn" type="button" aria-label="分享课文">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span>分享</span>
          </button>
        </div>
        <!-- Share dropdown -->
        <div class="share-dropdown" id="shareDropdown" hidden>
          <button class="share-item" data-share="copy" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            复制链接
          </button>
          <button class="share-item" data-share="weibo" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20c-4.038 0-7.32-2.011-7.32-4.5 0-2.49 3.282-4.5 7.32-4.5 4.037 0 7.32 2.01 7.32 4.5 0 2.489-3.283 4.5-7.32 4.5zM17.5 14.5c-.276 0-.5.224-.5.5 0 1.381-1.119 2.5-2.5 2.5-.276 0-.5.224-.5.5s.224.5.5.5c1.93 0 3.5-1.57 3.5-3.5 0-.276-.224-.5-.5-.5z"/></svg>
            微博
          </button>
          <button class="share-item" data-share="wechat" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2C4.768 2 1.5 4.671 1.5 7.97c0 1.882 1.058 3.563 2.711 4.677L3.5 14.5l2.5-1.25c.685.17 1.43.27 2.2.27h.25a5.5 5.5 0 0 1-.2-1.5c0-3.314 3.134-6 7-6 .25 0 .5.01.74.04C15.65 4.31 12.48 2 8.691 2zm-2.5 3.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm5 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM15.5 8c-3.314 0-6 2.462-6 5.5s2.686 5.5 6 5.5c.685 0 1.346-.094 1.964-.268L19.5 20l-.5-1.75c1.5-1.062 2.5-2.688 2.5-4.75 0-3.038-2.686-5.5-6-5.5zm-2 3a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm4 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
            微信
          </button>
          <div class="share-qr" id="shareQr" hidden>
            <canvas id="qrCanvas"></canvas>
            <p>用微信扫一扫</p>
          </div>
        </div>
        <!-- Table of contents -->
        <nav class="lesson-toc" id="lessonToc" aria-label="文章目录">
          <span class="toc-label">目录</span>
          <ul class="toc-list"></ul>
        </nav>
        <!-- Audio reading toolbar -->
        <div class="audio-toolbar" id="audioToolbar">
          <div class="audio-toolbar-info">
            <span class="audio-icon">🔊</span>
            <span class="audio-label">朗读本文</span>
          </div>
          <div class="audio-controls">
            <button class="audio-btn audio-play" id="audioPlay" type="button" aria-label="播放朗读">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              <span>播放</span>
            </button>
            <button class="audio-btn audio-pause" id="audioPause" type="button" aria-label="暂停朗读" hidden>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
              <span>暂停</span>
            </button>
            <button class="audio-btn audio-stop" id="audioStop" type="button" aria-label="停止朗读">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h12v12H6z"/></svg>
              <span>停止</span>
            </button>
            <div class="audio-speed">
              <label for="audioSpeed">语速</label>
              <select id="audioSpeed">
                <option value="0.75">0.75x</option>
                <option value="1" selected>1x</option>
                <option value="1.25">1.25x</option>
                <option value="1.5">1.5x</option>
              </select>
            </div>
          </div>
          <span class="audio-status" id="audioStatus">点击播放，AI 朗读课文故事</span>
        </div>

        {/* Read-along recording mode */}
        <div class="readalong-toolbar" id="readalongToolbar">
          <div class="readalong-info">
            <span class="readalong-icon">🎤</span>
            <span class="readalong-label">我来读</span>
          </div>
          <div class="readalong-controls">
            <button class="readalong-btn" id="readalongRecord" type="button" aria-label="开始录音">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="10"/></svg>
              <span>开始录音</span>
            </button>
            <button class="readalong-btn" id="readalongStop" type="button" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
              <span>停止</span>
            </button>
            <button class="readalong-btn" id="readalongPlay" type="button" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              <span>回放</span>
            </button>
            <button class="readalong-btn readalong-checkin" id="readalongCheckin" type="button" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <span>打卡</span>
            </button>
          </div>
          <span class="readalong-status" id="readalongStatus">朗读课文，录音后回放对比</span>
        </div>

        {/* Add note floating button (appears when text is selected) */}
        <button class="add-note-fab" id="addNoteFab" type="button" hidden>
          📝 添加笔记
        </button>
        <div class="story-content" id="storyContent">
          <Content />
        </div>
      </div>
      <aside class="side-panel">
        <section class="side-card fun-fact-card">
          <h2><span class="side-icon">💡</span> 有趣冷知识</h2>
          <p>{data.funFact}</p>
        </section>

        {/* Knowledge Graph */}
        <section class="side-card knowledge-graph-card">
          <h2><span class="side-icon">🕸️</span> 知识图谱</h2>
          <div class="kg-container" id="kgContainer"
            data-title={data.title}
            data-author={lessonAuthors.join("、")}
            data-era={data.era}
            data-theme={data.theme}
            data-grade={data.grade}
            data-related={JSON.stringify(related.slice(0, 3).map((r: any) => ({ title: r.lesson.data.title, slug: r.lesson.slug, reason: r.reasons[0] })))}
          >
            <svg class="kg-svg" id="kgSvg" viewBox="0 0 280 240" aria-label="课文知识图谱"></svg>
          </div>
        </section>

        {/* Reading Notes */}
        <section class="side-card notes-card" id="notesCard">
          <h2><span class="side-icon">📝</span> 我的笔记</h2>
          <p class="notes-hint">选中正文中的文字，点击"添加笔记"按钮记录你的想法。</p>
          <div class="notes-list" id="notesList"></div>
        </section>

        {/* Note Modal */}
        <div class="note-modal-overlay" id="noteModalOverlay" hidden>
          <div class="note-modal">
            <h3 class="note-modal-title">添加笔记</h3>
            <p class="note-modal-quote" id="noteModalQuote"></p>
            <textarea class="note-modal-input" id="noteModalInput" placeholder="写下你的想法..." rows="4"></textarea>
            <div class="note-modal-actions">
              <button class="note-modal-cancel" id="noteModalCancel" type="button">取消</button>
              <button class="note-modal-save" id="noteModalSave" type="button">保存笔记</button>
            </div>
          </div>
        </div>

        <section class="side-card questions-card">
          <h2><span class="side-icon">🤔</span> 想一想</h2>
          <ol>
            {data.questions.map((question) => <li>{question}</li>)}
          </ol>
        </section>
        <section class="side-card takeaways-card">
          <h2><span class="side-icon">✨</span> 我学到了</h2>
          <ul>
            {data.takeaways.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        {/* Background Knowledge */}
        <section class="side-card background-card" id="backgroundCard" data-era={data.era} data-theme={data.theme} data-title={data.title}>
          <h2><span class="side-icon">🏛️</span> 背景知识</h2>
          <div class="background-content" id="backgroundContent">
            <p class="background-loading">正在加载背景知识…</p>
          </div>
        </section>

        {/* Writing Inspiration */}
        <section class="side-card writing-card" id="writingCard" data-theme={data.theme} data-title={data.title} data-grade={data.grade}>
          <h2><span class="side-icon">✏️</span> 仿写小练笔</h2>
          <div class="writing-content" id="writingContent">
            <p class="writing-loading">正在准备写作提示…</p>
          </div>
        </section>
      </aside>
    </div>

    <section class="glossary">
      <div class="section-heading compact-heading">
        <div>
          <p class="eyebrow">照顾小读者</p>
          <h2>生字词小字典</h2>
        </div>
        <p>正文里遇到这些词，可以先看拼音，再读解释。</p>
      </div>
      <div class="glossary-grid">
        {data.glossary.map((item) => (
          <article class="glossary-card">
            <h3>
              <ruby>{item.term}<rt>{item.pinyin}</rt></ruby>
            </h3>
            <p>{item.meaning}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Interactive quiz module -->
    <section class="interactive-quiz" id="interactiveQuiz" data-glossary={JSON.stringify(data.glossary)} data-questions={JSON.stringify(data.questions)}>
      <div class="section-heading compact-heading">
        <div>
          <p class="eyebrow">动手练一练</p>
          <h2>互动小课堂</h2>
        </div>
        <p>听写生字词，或做个小测试，看看你记住了多少。</p>
      </div>

      <div class="quiz-tabs" role="tablist" aria-label="练习模式">
        <button class="quiz-tab active" role="tab" aria-selected="true" data-mode="dictation" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          生字词听写
        </button>
        <button class="quiz-tab" role="tab" aria-selected="false" data-mode="match" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          词义匹配
        </button>
        <button class="quiz-tab" role="tab" aria-selected="false" data-mode="discuss" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          读后思考
        </button>
        <button class="quiz-tab" role="tab" aria-selected="false" data-mode="fillblank" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          填空题
        </button>
        <button class="quiz-tab" role="tab" aria-selected="false" data-mode="ordering" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          排序题
        </button>
        <button class="quiz-tab" role="tab" aria-selected="false" data-mode="truefalse" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          判断题
        </button>
      </div>

      <!-- Dictation mode -->
      <div class="quiz-panel active" id="panelDictation" role="tabpanel">
        <div class="quiz-start-screen" id="dictStart">
          <p class="quiz-intro">点击"开始听写"，AI 会朗读每个生字词。请根据读音写出对应的汉字，写完一个词点击"下一个"。</p>
          <button class="quiz-start-btn" id="dictStartBtn" type="button">开始听写</button>
        </div>
        <div class="quiz-play-screen" id="dictPlay" hidden>
          <div class="quiz-progress">
            <span id="dictProgress">第 1 / 4 题</span>
            <span class="quiz-score" id="dictScore">得分：0</span>
          </div>
          <div class="dictation-item">
            <button class="dict-play-btn" id="dictPlayBtn" type="button" aria-label="重新播放读音">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
              再听一遍
            </button>
            <div class="dict-input-area">
              <label for="dictInput">写出你听到的词语：</label>
              <input type="text" id="dictInput" class="dict-input" placeholder="在这里输入汉字" autocomplete="off" />
            </div>
            <div class="dict-feedback" id="dictFeedback"></div>
            <div class="quiz-actions">
              <button class="quiz-check-btn" id="dictCheckBtn" type="button">提交答案</button>
              <button class="quiz-next-btn" id="dictNextBtn" type="button" hidden>下一个 →</button>
            </div>
          </div>
        </div>
