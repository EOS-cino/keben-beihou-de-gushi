    <section class="sources">
      <h2><span class="side-icon">📚</span> 资料来源</h2>
      <ul>
        {data.sources.map((source) => (
          <li><a href={source.url} target="_blank" rel="noreferrer">{source.name}</a></li>
        ))}
      </ul>
    </section>

    <nav class="lesson-nav" aria-label="课文导航">
      {prev && (
        <a class="nav-card nav-prev" href={withBase(`/lessons/${prev.slug}/`)}>
          <span class="nav-label">← 上一篇</span>
          <span class="nav-title">《{prev.data.title}》</span>
          <span class="nav-meta">{prev.data.grade} · {prev.data.theme}</span>
        </a>
      )}
      {next && (
        <a class="nav-card nav-next" href={withBase(`/lessons/${next.slug}/`)}>
          <span class="nav-label">下一篇 →</span>
          <span class="nav-title">《{next.data.title}》</span>
          <span class="nav-meta">{next.data.grade} · {next.data.theme}</span>
        </a>
      )}
