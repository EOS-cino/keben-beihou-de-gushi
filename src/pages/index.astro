---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LessonCard from "../components/LessonCard.astro";
import fs from "fs";
import path from "path";
import { getCurrentSeasonal, fallbackSeasonal } from "../data/seasonal";

const gradeOrder = ["一年级", "二年级", "三年级", "四年级", "五年级", "六年级"];
const allLessons = await getCollection("lessons");
const lessons = allLessons.sort((a, b) => {
  const ga = gradeOrder.indexOf(a.data.grade);
  const gb = gradeOrder.indexOf(b.data.grade);
  return ga - gb;
});
const featuredLessons = lessons.filter((lesson) => lesson.data.featured).slice(0, 8);

// Seasonal recommendations
const currentSeason = getCurrentSeasonal();
const seasonalEntries = currentSeason?.lessons || fallbackSeasonal;
const seasonalLessons = seasonalEntries
  .map((entry) => {
    const lesson = allLessons.find((l) => l.slug === entry.slug);
    return lesson ? { lesson, reason: entry.reason } : null;
  })
  .filter((item): item is { lesson: typeof allLessons[0]; reason: string } => item !== null)
  .slice(0, 4);

// Recently updated lessons (by file modification time)
const lessonsDir = path.resolve("./src/content/lessons");
const recentLessons = allLessons
  .map((lesson) => {
    const filePath = path.join(lessonsDir, `${lesson.slug}.md`);
    let mtime = 0;
    try { mtime = fs.statSync(filePath).mtimeMs; } catch {}
    return { lesson, mtime };
  })
  .sort((a, b) => b.mtime - a.mtime)
  .slice(0, 6)
  .map((item) => item.lesson);

const grades = gradeOrder.filter((grade) => lessons.some((lesson) => lesson.data.grade === grade));
const themes = [...new Set(lessons.map((lesson) => lesson.data.theme))];
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

const gradeIcons: Record<string, string> = {
  "一年级": "🌱",
  "二年级": "🌿",
  "三年级": "🌳",
  "四年级": "🏔️",
  "五年级": "🌊",
  "六年级": "🚀",
};

const features = [
  { icon: "📖", title: "原创导读", desc: "用孩子能懂的语言讲清课文核心，不照搬教材。" },
  { icon: "🎭", title: "背景故事", desc: "走进作者、时代、人物背后的真实世界。" },
  { icon: "💡", title: "有趣冷知识", desc: "把知识点变成孩子愿意记住的小惊喜。" },
  { icon: "🔤", title: "生字词字典", desc: "带拼音的生字词解释，照顾每一位小读者。" },
];
---

<BaseLayout
  title="课文背后的故事"
  description="面向小学生的语文课文背景故事网站，用故事、人物和时代背景激发阅读兴趣。"
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">小学语文 · 背景故事 · 延伸阅读</p>
      <h1>把课文读成一场<br />有来处的探索</h1>
      <p>
        这里不搬运教材全文，而是用孩子能读懂的语言讲清作者、时代、人物和有趣细节。
        每篇文章都配有思考问题、知识卡片和资料来源，适合课前预习、课后拓展和亲子共读。
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("/lessons/")}>浏览全部课文</a>
        <a class="button secondary" href="#featured">先看推荐</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="项目概览">
      <div class="stat">
        <strong>{lessons.length}</strong>
        <span>篇课文故事</span>
      </div>
      <div class="stat">
        <strong>{grades.length}</strong>
        <span>个年级段</span>
      </div>
      <div class="stat">
        <strong>{themes.length}</strong>
        <span>个阅读主题</span>
      </div>
    </div>
  </section>

  <section class="feature-strip" aria-label="网站特色">
    {features.map((feature) => (
      <div class="feature-item">
        <span class="feature-icon">{feature.icon}</span>
        <strong>{feature.title}</strong>
        <span>{feature.desc}</span>
      </div>
    ))}
  </section>

  <section class="band" id="featured">
    <div class="section-heading">
      <div>
        <p class="eyebrow">推荐开始</p>
        <h2>从这些课文进入故事现场</h2>
      </div>
      <a class="text-link" href={withBase("/lessons/")}>查看全部 →</a>
    </div>
    <div class="card-grid">
      {featuredLessons.map((lesson) => <LessonCard lesson={lesson} />)}
    </div>
  </section>

  {seasonalLessons.length > 0 && (
    <section class="band seasonal-band" id="seasonal">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{currentSeason?.emoji ?? "📚"} {currentSeason?.name ?? "今日推荐"}</p>
          <h2>应季阅读推荐</h2>
        </div>
        <a class="text-link" href={withBase("/lessons/")}>查看全部 →</a>
      </div>
      <div class="card-grid seasonal-grid">
        {seasonalLessons.map((item) => (
          <div class="seasonal-card-wrapper">
            <LessonCard lesson={item.lesson} />
            <p class="seasonal-reason">📌 {item.reason}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="band">
    <div class="section-heading">
      <div>
        <p class="eyebrow">按年级浏览</p>
        <h2>找到你正在学的课文</h2>
      </div>
      <a class="text-link" href={withBase("/lessons/")}>查看全部 →</a>
    </div>
    <div class="grade-jump">
      {grades.map((grade) => (
        <a href={withBase("/lessons/")}>
          <span class="grade-icon">{gradeIcons[grade] ?? "📚"}</span>
          <span>{grade}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="band" id="recent">
    <div class="section-heading">
      <div>
        <p class="eyebrow">最近更新</p>
        <h2>新鲜出炉的课文故事</h2>
      </div>
      <a class="text-link" href={withBase("/lessons/")}>查看全部 →</a>
    </div>
    <div class="card-grid">
      {recentLessons.map((lesson) => <LessonCard lesson={lesson} />)}
    </div>
  </section>

  <section class="reading-path-band">
    <div class="reading-path-content">
      <div>
        <p class="eyebrow">阅读路径</p>
        <h2>一篇课文，四步读深一点</h2>
        <p class="reading-path-intro">
          每篇文章不是百科词条，而是用故事化的结构引导孩子逐步深入，从"知道讲什么"到"带着问题回读"。
        </p>
      </div>
      <ol class="steps steps-enhanced">
        <li>
          <span class="step-number">1</span>
          <strong>先知道讲什么</strong>
          <span>用短摘要抓住课文核心，不替代原课文阅读。</span>
        </li>
        <li>
          <span class="step-number">2</span>
          <strong>再走进背景</strong>
          <span>看看人物、时代、地点和真实故事。</span>
        </li>
        <li>
          <span class="step-number">3</span>
          <strong>发现冷知识</strong>
          <span>把一个知识点变成孩子愿意记住的小惊喜。</span>
        </li>
        <li>
          <span class="step-number">4</span>
          <strong>带着问题回读</strong>
          <span>用开放问题引导表达、联想和复述。</span>
        </li>
      </ol>
    </div>
    <div class="reading-path-illustration">
      <img src={withBase("/images/reading-path-illustration.jpg")} alt="阅读探索之旅插画" loading="lazy" />
    </div>
  </section>

  <section class="cta-band">
    <div class="cta-content">
      <h2>准备好了吗？</h2>
      <p>从一篇课文开始，发现文字背后的世界。</p>
      <a class="button primary cta-button" href={withBase("/lessons/")}>开始探索课文故事</a>
    </div>
  </section>
</BaseLayout>
